{
	"compilerOptions": {
		"types": ["node", "svelte"],
		"baseUrl": ".",
		"inlineSources": true,
		"inlineSourceMap": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"removeComments": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ES2022"]
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules/*"]
}
